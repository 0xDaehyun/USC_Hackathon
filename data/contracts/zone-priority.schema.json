{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emberaid.example/schemas/zone-priority.schema.json",
  "title": "EmberAid Zone Priority Dataset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mode",
    "calculationStatus",
    "statusBasis",
    "incident",
    "dataAsOf",
    "scoringModel",
    "zones",
    "sourceRefs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "mode": {
      "enum": [
        "live",
        "historical-reconstruction",
        "what-if"
      ]
    },
    "calculationStatus": {
      "enum": [
        "illustrative",
        "unvalidated",
        "validated"
      ]
    },
    "statusBasis": {
      "enum": [
        "current-authoritative",
        "selected-official-checkpoint",
        "maximum-observed-during-incident",
        "hypothetical-input"
      ]
    },
    "incident": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "jurisdiction"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "jurisdiction": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dataAsOf": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "scoringModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "weights"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "dynamicThreat",
            "evacuationFriction",
            "supportNeed"
          ],
          "properties": {
            "dynamicThreat": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "evacuationFriction": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "supportNeed": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/zone"
      }
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    }
  },
  "$defs": {
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "zone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zoneId",
        "displayName",
        "evacuationStatus",
        "priorityScore",
        "priorityLevel",
        "components",
        "confidence",
        "reasons",
        "actions",
        "sourceIds"
      ],
      "properties": {
        "zoneId": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "evacuationStatus": {
          "enum": [
            "Evacuation Order",
            "Evacuation Warning",
            "Advisory",
            "None",
            "Unknown"
          ]
        },
        "priorityScore": {
          "$ref": "#/$defs/score"
        },
        "priorityLevel": {
          "enum": [
            "very-high",
            "high",
            "medium",
            "low"
          ]
        },
        "components": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "dynamicThreat",
            "evacuationFriction",
            "supportNeed"
          ],
          "properties": {
            "dynamicThreat": {
              "$ref": "#/$defs/score"
            },
            "evacuationFriction": {
              "$ref": "#/$defs/score"
            },
            "supportNeed": {
              "$ref": "#/$defs/score"
            }
          }
        },
        "confidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "level",
            "notes"
          ],
          "properties": {
            "level": {
              "enum": [
                "high",
                "medium",
                "low"
              ]
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "category",
              "label",
              "verificationRequired"
            ],
            "properties": {
              "category": {
                "enum": [
                  "transport",
                  "language",
                  "shelter",
                  "health",
                  "outreach"
                ]
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "verificationRequired": {
                "const": true
              }
            }
          }
        },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "url"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
